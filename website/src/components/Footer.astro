---
---

<footer class="border-t border-border mt-auto relative">
  <!-- Subtle gradient fade at top -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/20 to-transparent" />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <h3 class="font-display font-bold text-text-primary mb-3">AbsolutelySkilled</h3>
        <p class="text-sm text-text-secondary">
          A registry of production-ready skills for AI coding agents.
        </p>
      </div>
      <div>
        <h4 class="font-semibold text-text-primary mb-3 text-sm">Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/skills" class="text-text-secondary hover:text-text-primary transition-colors">Browse Skills</a></li>
          <li><a href="/agents" class="text-text-secondary hover:text-text-primary transition-colors">AI Agents</a></li>
          <li><a href="/blog" class="text-text-secondary hover:text-text-primary transition-colors">Blog</a></li>
          <li>
            <a
              href="https://github.com/AbsolutelySkilled/AbsolutelySkilled/issues/new?template=skill_request.yml&title=%5BSkill+Request%5D+%3Cskill+name%3E"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-text-primary transition-colors"
            >
              Request a Skill
            </a>
          </li>
          <li>
            <a
              href="https://github.com/AbsolutelySkilled/AbsolutelySkilled/blob/main/CONTRIBUTING.md"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-text-primary transition-colors"
            >
              Contributing
            </a>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="font-semibold text-text-primary mb-3 text-sm">Community</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a
              href="https://github.com/AbsolutelySkilled/AbsolutelySkilled"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-text-primary transition-colors"
            >
              GitHub
            </a>
          </li>
          <li>
            <a
              href="https://github.com/AbsolutelySkilled/AbsolutelySkilled/issues"
              target="_blank"
              rel="noopener noreferrer"
              class="text-text-secondary hover:text-text-primary transition-colors"
            >
              Issues
            </a>
          </li>
          <li><a href="/sitemap.xml" class="text-text-secondary hover:text-text-primary transition-colors">Sitemap</a></li>
          <li><a href="/llms.txt" class="text-text-secondary hover:text-text-primary transition-colors">llms.txt</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-border mt-8 pt-8 text-center text-sm text-text-muted">
      <p>&copy; {new Date().getFullYear()} AbsolutelySkilled. MIT License.</p>
      <p class="mt-2 text-text-muted/60">Crafted using the <a href="/skill/auto-engineer" class="text-primary-light/70 hover:text-primary-light transition-colors">auto-engineer</a> skill</p>
    </div>
  </div>
</footer>
