---
import BaseLayout from '../layouts/BaseLayout.astro';
import SkillCard from '../components/SkillCard.astro';
import FlagshipCard from '../components/FlagshipCard.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import StatsCounter from '../components/StatsCounter.astro';
import RecentSkills from '../components/RecentSkills.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import { getAllSkills, getSkillsByCategory, type Skill } from '../lib/skills';
import { getTotalInstalls, getTopSkillsByCounts } from '../lib/installs';
import { getHomePageSEO } from '../lib/seo';
import { getCollection } from 'astro:content';

const skills = getAllSkills();
const grouped = getSkillsByCategory(skills);
const totalInstalls = getTotalInstalls();
const seo = getHomePageSEO();

const categories = Object.entries(grouped)
  .map(([category, skills]) => ({ category, count: skills.length }))
  .sort((a, b) => b.count - a.count);

const topSkills = getTopSkillsByCounts(
  skills.map((s) => s.slug),
  5
);

const flagshipSkills = skills.filter((s) => s.slug.startsWith('absolute-') || s.slug === 'auto-engineer');

const recentSkills = skills.slice(-10).reverse();

const blogPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title={seo.title} description={seo.description} canonical={seo.canonical} jsonLd={seo.jsonLd}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border">
    <!-- Dot grid background (Swiss) -->
    <div class="absolute inset-0 bg-[radial-gradient(circle,rgba(148,163,184,0.06)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none" />
    <!-- Radial glow - teal, centered higher -->
    <div class="absolute top-[-100px] left-1/2 -translate-x-1/2 w-[1000px] h-[700px] bg-[radial-gradient(ellipse_at_center,oklch(0.60_0.12_180_/_0.12)_0%,transparent_70%)] pointer-events-none" />

    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-16 sm:pt-24 sm:pb-24 text-center relative">
      <!-- Agent badges bar -->
      <div class="flex items-center justify-center gap-2 sm:gap-3 flex-wrap mb-12">
        {['Claude Code', 'Cursor', 'Windsurf', 'GitHub Copilot', 'Gemini CLI', 'OpenAI Codex', 'Kilo Code', 'Amp'].map((name) => (
          <span class="inline-flex items-center px-3 py-1.5 rounded-full border border-border bg-card/60 backdrop-blur-sm text-xs text-text-secondary">
            {name}
          </span>
        ))}
        <span class="inline-flex items-center px-3 py-1.5 rounded-full border border-border bg-card/60 backdrop-blur-sm text-xs text-text-muted">
          +40 more
        </span>
      </div>

      <!-- Logo + Heading -->
      <img src="/logo.png" alt="AbsolutelySkilled logo" class="w-20 h-20 mx-auto mb-6" width="80" height="80" fetchpriority="high" />

      <h1 class="text-5xl sm:text-7xl lg:text-8xl font-bold font-display mb-4 tracking-tight leading-[0.95]">
        <span class="text-text-secondary">Teach your AI agent</span>
        <br />
        <span class="text-primary-light">anything.</span>
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
        {skills.length}+ production-ready skills for Claude Code, Gemini CLI, OpenAI Codex, and 40+ more agents. From clean code to marketing strategy.
      </p>

      <!-- Install command -->
      <div class="max-w-xl mx-auto mb-8">
        <div class="install-block justify-center text-base">
          <code class="text-text-primary">npx skills add AbsolutelySkilled/AbsolutelySkilled</code>
        </div>
      </div>

      <!-- CTAs - bigger -->
      <div class="flex items-center justify-center gap-4 mb-16">
        <a
          href="#skills"
          class="px-8 py-3.5 rounded-xl bg-primary text-white text-sm font-semibold hover:bg-primary-light transition-colors"
        >
          Browse Skills
        </a>
        <a
          href="https://github.com/AbsolutelySkilled/AbsolutelySkilled"
          target="_blank"
          rel="noopener noreferrer"
          class="px-8 py-3.5 rounded-xl border border-border text-sm font-semibold text-text-secondary hover:text-primary-light hover:border-primary/40 transition-colors"
        >
          View on GitHub
        </a>
      </div>

      <!-- Stats as glassmorphic cards -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 max-w-3xl mx-auto">
        <div class="stat-card">
          <svg class="w-5 h-5 text-primary-light mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 0 0-1.883 2.542l.857 6a2.25 2.25 0 0 0 2.227 1.932H19.05a2.25 2.25 0 0 0 2.227-1.932l.857-6a2.25 2.25 0 0 0-1.883-2.542m-16.5 0V6A2.25 2.25 0 0 1 6 3.75h3.879a1.5 1.5 0 0 1 1.06.44l2.122 2.12a1.5 1.5 0 0 0 1.06.44H18A2.25 2.25 0 0 1 20.25 9v.776" />
          </svg>
          <div class="text-2xl sm:text-3xl font-bold font-display text-text-primary">{skills.length}</div>
          <div class="text-xs text-text-muted mt-0.5">Skills</div>
        </div>
        <div class="stat-card">
          <svg class="w-5 h-5 text-primary-light mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z" />
          </svg>
          <div class="text-2xl sm:text-3xl font-bold font-display text-text-primary">{categories.length}</div>
          <div class="text-xs text-text-muted mt-0.5">Categories</div>
        </div>
        <div class="stat-card" data-installs-wrapper class:list={[totalInstalls <= 0 && 'hidden']}>
          <svg class="w-5 h-5 text-primary-light mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          <div class="text-2xl sm:text-3xl font-bold font-display text-text-primary" data-installs-total>{totalInstalls > 0 ? totalInstalls.toLocaleString() : ''}</div>
          <div class="text-xs text-text-muted mt-0.5">Installs</div>
        </div>
        <div class="stat-card">
          <svg class="w-5 h-5 text-primary-light mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
          </svg>
          <div class="text-2xl sm:text-3xl font-bold font-display text-text-primary">40+</div>
          <div class="text-xs text-text-muted mt-0.5">Agents</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Flagship Skills -->
  <section class="py-16" id="skills">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-10">
        <h2 class="text-2xl font-bold font-display">Flagship Skills</h2>
        <span class="text-xs font-mono text-text-muted bg-elevated px-2.5 py-1 rounded-full border border-border">curated</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {flagshipSkills.map((skill) => (
          <FlagshipCard
            slug={skill.slug}
            name={skill.name}
            description={skill.description}
            category={skill.category}
            tags={skill.tags}
            featured
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="py-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-card/50 via-card/30 to-transparent pointer-events-none" />
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <h2 class="text-2xl font-bold font-display mb-8">Categories</h2>
      <CategoryGrid categories={categories} />
    </div>
  </section>

  <!-- Supported Agents - internal linking for agent pages -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold font-display">Works With Your Agent</h2>
        <a href="/agents" class="text-sm text-text-muted hover:text-primary-light transition-colors font-mono">
          All agents &rarr;
        </a>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        {[
          { name: 'Claude Code', slug: 'claude-code' },
          { name: 'Cursor', slug: 'cursor' },
          { name: 'Windsurf', slug: 'windsurf' },
          { name: 'GitHub Copilot', slug: 'github-copilot' },
          { name: 'Gemini CLI', slug: 'gemini-cli' },
          { name: 'OpenAI Codex', slug: 'openai-codex' },
        ].map((agent) => (
          <a
            href={`/agents/${agent.slug}`}
            class="card p-4 text-center group hover:border-border-hover transition-colors"
          >
            <span class="text-sm font-display font-semibold text-text-primary group-hover:text-primary-light transition-colors">
              {agent.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Recently Added -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold font-display mb-8">Recently Added</h2>
      <RecentSkills skills={recentSkills} />
    </div>
  </section>

  <!-- From the Blog -->
  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-2xl font-bold font-display">From the Blog</h2>
        <a href="/blog" class="text-sm text-text-muted hover:text-primary-light transition-colors font-mono">
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {blogPosts.map((post) => (
          <BlogPostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            date={post.data.date}
            tags={post.data.tags}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-card/50 via-card/30 to-transparent pointer-events-none" />
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <h2 class="text-2xl font-bold font-display mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {seo.faqEntries.map((faq) => (
          <details class="card p-5 group">
            <summary class="font-semibold text-text-primary cursor-pointer list-none flex items-center justify-between">
              {faq.q}
              <span class="text-text-muted group-open:rotate-180 transition-transform ml-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <p class="text-sm text-text-secondary leading-relaxed mt-3">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
